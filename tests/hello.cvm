// ─── hello.cvm  ───────────────────────────────────────
// Basic CVM++ features demo

print "Hello, CVM++!";

// Variables and arithmetic
let x = 10;
let y = 3;
print x + y;       // 13
print x - y;       // 7
print x * y;       // 30
print x / y;       // 3.333...

// String concatenation
let name = "World";
print "Hello, " + name + "!";

// Booleans and comparison
let a = 5;
let b = 10;
print a < b;       // true
print a == b;      // false
print a != b;      // true
